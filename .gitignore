dist/
build/
out/

# ─── Electron 빌드 ────────────────────────────────────────
player/release/
player/dist-electron/

# ─── Android 빌드 (소스는 커밋, 빌드 결과물은 제외) ──────
player/android/.gradle/
player/android/app/build/
player/android/build/
player/android/local.properties
player/android/captures/
player/android/.idea/

