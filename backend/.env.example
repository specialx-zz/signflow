# ──────────────────────────────────
# VueSign Backend Configuration
# ──────────────────────────────────

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/vuesign?schema=public"

# Authentication
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
SERVER_URL=http://localhost:3001

# File Uploads
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=104857600

# Cloudflare R2 Storage (Optional)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=vuesign-content
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Redis (Optional - for production clustering)
# REDIS_URL=redis://localhost:6379

# ──────────────────────────────────
# Weather API Keys (VueSign Phase W1)
# ──────────────────────────────────
# 기상청 공공데이터 (단기예보 + 중기예보)
# 발급: https://www.data.go.kr/ → "기상청_단기예보", "기상청_중기예보" 신청
# KMA_SERVICE_KEY=your_kma_service_key
#
# 에어코리아 (실시간 측정소별 대기오염정보)
# 발급: https://www.data.go.kr/ → "한국환경공단_에어코리아_대기오염정보" 신청
# AIRKOREA_SERVICE_KEY=your_airkorea_service_key
