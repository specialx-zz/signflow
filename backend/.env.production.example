# =====================================================
# VueSign Backend - 운영 환경 설정 예시
# 이 파일을 .env로 복사 후 실제 값으로 교체하세요
# =====================================================

DATABASE_URL="file:./prisma/prod.db"

# 반드시 강력한 랜덤 값으로 교체 (openssl rand -hex 32)
JWT_SECRET="<여기에-강력한-랜덤-시크릿-입력>"
JWT_EXPIRES_IN="7d"

PORT=3001
NODE_ENV=production
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=104857600

# 운영 서버의 실제 도메인
SERVER_URL=https://api.vuesign.com

# CORS 허용 오리진
# - 관리자 웹 프론트엔드 도메인
# - Capacitor Android 앱 오리진 (https://localhost 또는 capacitor://localhost)
# - Electron은 Origin 헤더를 보내지 않아 자동 허용됨
ALLOWED_ORIGINS=https://admin.vuesign.com,https://localhost,capacitor://localhost

# Cloudflare R2 Storage (운영 시 권장)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=vuesign-content
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
